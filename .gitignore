# Dependencies
node_modules/

# Build output (regenerated by `npm run build`)
com.lawrensen.hwinfo.sdPlugin/bin/
# Legal files staged into the pack by scripts/copy-koffi.mjs (source of truth: repo root)
com.lawrensen.hwinfo.sdPlugin/LICENSE
com.lawrensen.hwinfo.sdPlugin/NOTICE.md

# Stream Deck runtime logs
com.lawrensen.hwinfo.sdPlugin/logs/

# Packaged plugin (root output dir only)
/release/
*.streamDeckPlugin

# Internal working docs, machine-local agent config, and the private backup
# working dir. Kept out of the public repo; mirrored in-place to the private
# repo slawrensen/hwinfo-streamdeck-private (bare repo, see .private/README.md).
# Do not git add -f these.
/MARKETPLACE.md
/design/
/CLAUDE.md
/.claude/
/docs/release/
/.private/

# Maker Console brand assets: not plugin content; originals ride the private
# mirror (.private/backup.ps1).
/assets/brand/

# capture-pi.mjs intermediates: regenerated every release, consumed only by
# scripts/marketplace-shots.mjs; the doc-referenced copies are settings-panel.png
# and sensor-picker.png.
/docs/assets/img/pi-settings.png
/docs/assets/img/pi-picker.png
/docs/assets/img/pi-dial-text.png

# Misc
*.log
.DS_Store
