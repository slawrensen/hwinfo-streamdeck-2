{
	"name": "hwinfo-streamdeck",
	"version": "1.1.7",
	"private": true,
	"type": "module",
	"description": "Elgato Stream Deck plugin that displays live HWiNFO sensor readings on keys and dials",
	"author": "Stephen Lawrensen",
	"license": "MIT",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "rollup -c && node scripts/copy-koffi.mjs",
		"watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.lawrensen.hwinfo\"",
		"lint": "eslint src scripts test --max-warnings 0",
		"typecheck": "tsc --noEmit",
		"test": "tsx --test test/themes.test.ts test/key-renderer.test.ts test/dial-renderer.test.ts test/reader.test.ts test/state-screens.test.ts test/series.test.ts",
		"contact-sheet": "tsx scripts/contact-sheet.mjs",
		"docs-shots": "tsx scripts/gen-docs-shots.mjs",
		"probe": "tsx src/probe.ts",
		"e2e": "node scripts/e2e-harness.mjs",
		"e2e:resilience": "node scripts/e2e-resilience.mjs",
		"e2e:gadget": "node scripts/e2e-gadget.mjs",
		"e2e:dead-fallback": "node scripts/e2e-dead-fallback.mjs",
		"e2e:load": "node scripts/e2e-load.mjs",
		"suite:full": "node scripts/hygiene.mjs",
		"icons": "node scripts/gen-icons.mjs",
		"release:validate": "npm run lint && npm run typecheck && npm test && node scripts/validate-release-copy.mjs",
		"pack": "streamdeck pack com.lawrensen.hwinfo.sdPlugin --output release --force"
	},
	"dependencies": {
		"@elgato/streamdeck": "^1.4.1",
		"koffi": "^3.1.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@rollup/plugin-commonjs": "^29.0.3",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-terser": "^1.0.0",
		"@rollup/plugin-typescript": "^12.3.0",
		"@types/node": "^26.1.0",
		"eslint": "^10.6.0",
		"globals": "^17.7.0",
		"rollup": "^4.62.2",
		"sharp": "^0.35.3",
		"tslib": "^2.8.1",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"ws": "^8.21.0"
	}
}
